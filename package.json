{
  "name": "amazon-login-api-tests",
  "version": "1.0.0",
  "description": "REST API testing framework for Amazon.in login scenarios using TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "api-testing",
