# API Configuration
API_BASE_URL=https://api.amazon.in
API_TIMEOUT_MS=10000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_MS=1000

# Test Environment
NODE_ENV=test
LOG_LEVEL=info

# Test Credentials (Use .env in production, never commit actual credentials)
TEST_EMAIL=test.user@amazon.in
TEST_PASSWORD=TestPassword123!
TEST_INVALID_EMAIL=invalid@amazon.in
TEST_INVALID_PASSWORD=WrongPassword123!

# Browser Configuration (optional, for Playwright integration)
BROWSER=chrome
HEADLESS=true

# Logging
ENABLE_REQUEST_LOGGING=true
ENABLE_RESPONSE_LOGGING=true
